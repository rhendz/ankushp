{
  "name": "ankushp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "next dev --webpack",
    "dev": "cross-env INIT_CWD=$PWD next dev --webpack",
    "prebuild": "node scripts/run-contentlayer-build.mjs && node scripts/patch-contentlayer-json-imports.mjs",
    "build": "cross-env INIT_CWD=$PWD SKIP_CONTENTLAYER=true next build --webpack && node ./scripts/postbuild.mjs",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "lint": "eslint --fix app components lib layouts scripts --ext .js,.jsx,.ts,.tsx",
    "test:smoke": "playwright test",
    "test:smoke:headed": "playwright test --headed --project=chromium",
    "test:smoke:ci": "cross-env CI=1 playwright test --project=chromium --reporter=line",
    "agent:health": "bash ./scripts/agent-health-check.sh",
    "agent:ga:weekly": "bash ./scripts/ga-weekly-dashboard.sh",
    "agent:night:run": "bash ./scripts/night-runner.sh",
    "agent:night:install-cron": "bash ./scripts/install-night-runner-cron.sh",
    "blog:handoff:validate": "node scripts/blog-handoff-import.mjs validate",
    "blog:handoff:import": "node scripts/blog-handoff-import.mjs import",
    "blog:handoff:smoke": "node scripts/blog-handoff-import.mjs validate scripts/blog-handoff/samples/valid-collaborator-handoff.md",
    "test": "vitest run"
  },
  "dependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@next/third-parties": "^16.1.6",
    "@opentelemetry/api": "^1.9.0",
    "@radix-ui/react-accordion": "^1.2.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@types/three": "^0.160.0",
    "@upstash/redis": "^1.36.3",
    "@vercel/speed-insights": "^1.0.9",
    "autoprefixer": "^10.4.17",
    "contentful": "^11.7.19",
    "contentful-management": "^11.58.0",
    "contentful-sdk-core": "^9.2.0",
    "contentlayer2": "^0.5.8",
    "date-fns": "^3.2.0",
    "dotenv-expand": "^11.0.6",
    "esbuild": "^0.19.11",
    "github-slugger": "^1.4.0",
    "gray-matter": "^4.0.3",
    "image-size": "^1.1.1",
    "kbar": "0.1.0-beta.45",
    "lucide-react": "^0.464.0",
    "mermaid": "^11.4.1",
    "next": "^16.1.6",
    "next-contentlayer2": "^0.5.8",
    "next-themes": "^0.4.6",
    "nextjs-google-analytics": "^2.3.3",
    "pliny": "^0.4.1",
    "postcss": "^8.4.24",
    "postprocessing": "^6.34.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.0.0",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^6.1.0",
    "rehype-citation": "^1.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-preset-minify": "6.0.0",
    "rehype-prism-plus": "^1.6.0",
    "rehype-slug": "^5.1.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^3.3.3",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@svgr/webpack": "^8.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/mdx": "^2.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.0",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^5.0.0",
    "globals": "^17.4.0",
    "husky": "^8.0.0",
    "jsdom": "^24.1.3",
    "lint-staged": "^13.0.0",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.4.1",
    "typescript": "^5.1.3",
    "vitest": "^1.6.0"
  },
  "overrides": {
    "kbar": "0.1.0-beta.45"
  },
  "resolutions": {
    "@opentelemetry/api": "1.4.1",
    "@opentelemetry/core": "1.13.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.39.1",
    "@opentelemetry/resources": "1.13.0",
    "@opentelemetry/sdk-trace-base": "1.13.0",
    "@opentelemetry/sdk-trace-node": "1.13.0",
    "@opentelemetry/semantic-conventions": "1.13.0"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  }
}
